{
    "_comment": "请将本文件复制到你的用户配置目录（如 C:/Users/<你的用户名>/AppData/Local/YourAppNameOrAuthor/alphaHomeApp/config.json），并根据实际情况填写数据库和API信息。",
    "database": {
        "url": "postgresql://username:password@localhost:5432/alphadb",
    "mv_refresh_timeout_seconds": 7200,
    "mv_row_count_timeout_seconds": 60,
        "pool_config": {
            "_comment": "数据库连接池配置 - 用于优化批量数据操作性能",
            "min_size": 5,
            "max_size": 25,
            "command_timeout": 180,
            "max_queries": 50000,
            "max_inactive_connection_lifetime": 300,
            "server_settings": {
                "_comment": "PostgreSQL 服务器设置 - 优化连接性能",
                "application_name": "alphahome_fetcher",
                "tcp_keepalives_idle": "600",
                "tcp_keepalives_interval": "30",
                "tcp_keepalives_count": "3",
                "jit": "off"
            }
        }
    },
    "api": {
        "tushare_token": "your_tushare_token_here",
        "ifind": {
            "base_url": "https://quantapi.51ifind.com/api/v1/",
            "refresh_token": "your_ifind_refresh_token_here"
        },
        "tinysoft": {
            "_comment": "Tinysoft(pyTSL) 连接配置。可二选一：1) 填 user/password/host/port；2) 仅填 ini_path",
            "user": "your_tinysoft_user",
            "password": "your_tinysoft_password",
            "host": "tsl.tinysoft.com.cn",
            "port": 443,
            "service": "",
            "timeout_ms": 45000,
            "request_interval": 0.2,
            "ini_path": ""
        }
    },
    "dolphindb": {
        "_comment": "DolphinDB 单机版连接配置（用于5分钟K线与技术因子加速层）",
        "host": "localhost",
        "port": 8848,
        "username": "your_ddb_username",
        "password": "your_ddb_password"
    },
    "performance": {
        "_comment": "性能监控和优化配置",
        "enable_monitoring": true,
        "max_history_records": 100,
        "log_slow_operations": true,
        "slow_operation_threshold": 10.0,
        "auto_batch_size_optimization": false
    },
    "tasks": {
        "_comment": "在此处为特定任务覆盖默认设置",
        "akshare_macro_china_nbs_nation": {
            "_comment": "国家统计局 NBS 通用全国宏观：配置 series 列表，每个 series 对应 kind/path/period。kind/path 需与 stats.gov.cn 页面层级匹配（建议手动维护）。",
            "concurrent_limit": 1,
            "series": [
                {
                    "id": "gdp_annual",
                    "kind": "年度数据",
                    "path": "<例如：国民经济核算 > 国内生产总值>",
                    "period": "LAST10"
                },
                {
                    "id": "cpi_monthly",
                    "kind": "月度数据",
                    "path": "<例如：价格指数 > 居民消费价格指数(CPI)>",
                    "period": "LAST120"
                }
            ]
        },
        "tushare_stock_daily": {
            "save_batch_size": 5000,
            "concurrent_limit": 10,
            "max_retries": 3,
            "retry_delay": 1
        },
        "tushare_stock_factor_pro": {
            "save_batch_size": 5000,
            "concurrent_limit": 5
        },
        "tushare_stock_basic": {
            "update_frequency": "daily"
        },
        "tinysoft_stock_minute": {
            "_comment": "默认全市场分钟线；symbol_batch_size 控制每个批次内的股票组大小；normalize_units=true 时将 TinySoft 原始单位股/元归一化为手/千元；如需仅抓部分股票，设置 use_config_symbols=true 并填写 ts_codes（可配 max_symbols）",
            "cycle": "1分钟线",
            "batch_days": 1,
            "symbol_batch_size": 50,
            "use_config_symbols": false,
            "skip_failed_symbols": true,
            "normalize_units": true,
            "volume_scale": 0.01,
            "amount_scale": 0.001,
            "enable_quality_checks": true,
            "quality_check_days": 20,
            "quality_check_coverage_warn_threshold": 0.95,
            "quality_check_reconcile_days": 5,
            "enforce_coverage_threshold": true,
            "coverage_fail_on_breach": false,
            "persist_quality_checks": true,
            "quality_checks_table": "tinysoft.stock_minute_quality_checks",
            "concurrent_limit": 2,
            "query_timeout_ms": 45000
        },
        "tinysoft_index_minute": {
            "_comment": "默认抓取可映射到 TinySoft 原码的国内指数分钟线；支持传 ts_codes=000001.SH/000300.CSI 或 TinySoft 原码 SH000001/CSI000300",
            "cycle": "1分钟线",
            "batch_days": 1,
            "symbol_batch_size": 50,
            "use_config_symbols": false,
            "skip_failed_symbols": true,
            "normalize_units": true,
            "volume_scale": 0.01,
            "amount_scale": 0.001,
            "concurrent_limit": 2,
            "query_timeout_ms": 45000
        },
        "tinysoft_fund_minute": {
            "_comment": "默认抓取场内基金（ETF/LOF 等）分钟线；从 fund_basic/fund_etf_basic 读取 SH/SZ 场内代码",
            "cycle": "1分钟线",
            "batch_days": 1,
            "symbol_batch_size": 50,
            "use_config_symbols": false,
            "skip_failed_symbols": true,
            "normalize_units": true,
            "volume_scale": 0.01,
            "amount_scale": 0.001,
            "concurrent_limit": 2,
            "query_timeout_ms": 45000
        },
        "tinysoft_stock_suspend": {
            "_comment": "停牌事件（表127 InfoArray）；默认全市场，按停牌开始日过滤并入库",
            "symbol_batch_size": 50,
            "use_config_symbols": false,
            "skip_failed_symbols": true,
            "infoarray_table_id": 127,
            "include_empty_events": false,
            "concurrent_limit": 2,
            "query_timeout_ms": 45000
        },
        "tinysoft_stock_industry_versioned": {
            "_comment": "行业版本化（表139 InfoArray）；默认全行业源，可用 source_codes 过滤（如 SWHY/CSRCHY）",
            "symbol_batch_size": 50,
            "use_config_symbols": false,
            "skip_failed_symbols": true,
            "include_empty_records": false,
            "infoarray_table_id": 139,
            "source_codes": [],
            "concurrent_limit": 2,
            "query_timeout_ms": 45000
        },
        "tinysoft_stock_fina_pit_ext": {
            "_comment": "财务 PIT 扩展（默认表42）；按公布日/截止日展开并保留字段ID与report表达式",
            "symbol_batch_size": 30,
            "use_config_symbols": false,
            "skip_failed_symbols": true,
            "include_empty_metrics": false,
            "metric_profiles": [
                {
                    "finance_source": "report_42_main",
                    "table_id": 42,
                    "metric_defs": [
                        {
                            "metric_name": "eps_diluted",
                            "field_id": 42002,
                            "field_name": "每股收益(摊薄)"
                        },
                        {
                            "metric_name": "bps",
                            "field_id": 42006,
                            "field_name": "每股净资产"
                        },
                        {
                            "metric_name": "roe_diluted",
                            "field_id": 42012,
                            "field_name": "净资产收益率(摊薄)(%)"
                        },
                        {
                            "metric_name": "netprofit_excl_nr",
                            "field_id": 42017,
                            "field_name": "扣除非经常性损益后的净利润"
                        }
                    ]
                }
            ],
            "concurrent_limit": 2,
            "query_timeout_ms": 45000
        }
    },
    "backtesting": {
        "default_cash": 100000,
        "default_commission": 0.001,
        "cache_data": true,
        "max_cache_size": 1000,
        "hikyuu_data_dir": "E:/stock",
        "default_start_date": "2023-01-01",
        "default_end_date": "2023-12-31",
        "default_table": "tushare_stock_daily"
    }
}
